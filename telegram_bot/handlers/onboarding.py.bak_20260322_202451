    text = update.message.text.strip().lower()
    if "high" in text or "climbing" in text or "comrades" in text or "trail" in text:
        hilliness = "high"
        label = "🏔️ High"
    elif "medium" in text or "rolling" in text:
        hilliness = "medium"
        label = "🌄 Medium"
    else:
        hilliness = "low"
        label = "🏙️ Low"

    context.user_data["race_hilliness"] = hilliness

    await update.message.reply_text(
        f"Got it — *{label}* terrain.\n\n"
        "📍 *Last step — where are you based?*\n\n"
        "This enables *TRUEPACE*: weather-adjusted paces shown each time you view your plan. "
        "Select your nearest city or skip:",
        reply_markup=_city_keyboard(),
        parse_mode="Markdown",
    )
    return LOCATION


# ── Q8 / Q3-C25K: Location ────────────────────────────────────────────────

async def get_location(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    from coach_core.engine.sa_cities import find_city

    text = update.message.text.strip()
    plan_type = context.user_data.get("plan_type", "full")

    lat = lon = None
    city_label = None

    if "skip" in text.lower():
        city_label = None   # no location saved
    else:
        city = find_city(text)
        if city:
            lat, lon = city.latitude, city.longitude
            city_label = f"{city.name} ({city.province})"
        else:
            # Show keyboard again with error
            await update.message.reply_text(
                f"❌ *{text}* not recognised.\n\n"
                "Please choose from the list or tap *⏭️ Skip for now*:",
                reply_markup=_city_keyboard(),
                parse_mode="Markdown",
            )
            return LOCATION

    # ── Create the athlete profile ─────────────────────────────────────────
    telegram_id = str(update.effective_user.id)
    today = date.today()

    if plan_type == "c25k":
        payload = {
            "telegram_id": telegram_id,
            "name": context.user_data["name"],
            "start_date": today.isoformat(),
        }
        async with httpx.AsyncClient(timeout=10) as client:
            try:
                r = await client.post(f"{API_BASE_URL}/athlete/c25k", json=payload)
                if r.status_code == 409:
                    await update.message.reply_text(
                        "You already have a profile. Use /plan to see your workouts, or /reset to start over.",
                        reply_markup=ReplyKeyboardRemove(),
                    )
                    return ConversationHandler.END
                r.raise_for_status()
            except Exception as e:
                await update.message.reply_text(
                    f"❌ Setup failed: {e}\nPlease try /start again.",
                    reply_markup=ReplyKeyboardRemove(),
                )
                return ConversationHandler.END

    else:
        payload = {
            "telegram_id": telegram_id,
            "name": context.user_data["name"],
            "current_weekly_mileage": context.user_data["mileage"],
            "vdot": context.user_data["vdot"],
            "race_distance": context.user_data["race_distance"],
            "race_date": context.user_data["race_date"],
            "race_hilliness": context.user_data["race_hilliness"],
            "start_date": today.isoformat(),
        }
        success, err = await _save_athlete_full(telegram_id, payload)
        if not success:
            if err == "existing_profile":
                await update.message.reply_text(
                    "You already have a profile. Use /plan to see your week, or /reset to start over.",
                    reply_markup=ReplyKeyboardRemove(),
                )
            else:
                await update.message.reply_text(
                    f"❌ Setup failed: {err}\nPlease try /start again.",
                    reply_markup=ReplyKeyboardRemove(),
                )
            return ConversationHandler.END

    # ── Save location if provided ──────────────────────────────────────────
    if lat is not None:
        async with httpx.AsyncClient(timeout=10) as client:
            try:
                await client.patch(
                    f"{API_BASE_URL}/athlete/{telegram_id}/location",
                    json={"latitude": lat, "longitude": lon, "run_hour": 7},
                )
            except Exception:
                pass   # location save failure is non-fatal

    # ── Fetch and display Week 1 ───────────────────────────────────────────
    week = await _fetch_current_week(telegram_id)
    if not week:
        await update.message.reply_text(
            "✅ Profile created! Use /plan to see your first week.",
            reply_markup=ReplyKeyboardRemove(),
        )
        return ConversationHandler.END

    name = context.user_data["name"]
    loc_note = f" — 📍 {city_label}" if city_label else " _(add /location anytime for weather paces)_"

    if plan_type == "c25k":
        intro = f"✅ You're enrolled, *{name}*!{loc_note}\n\nHere's *Week 1*:\n\n"
        plan_text = format_c25k_week(week)
        help_text = C25K_COMMANDS_HELP
    else:
        vdot = context.user_data.get("vdot", "?")
        dist = context.user_data.get("race_distance", "")
        intro = f"✅ Plan created, *{name}*! VDOT *{vdot}*{loc_note}\n\nHere's *Week 1*:\n\n"
        plan_text = format_week(week)
        help_text = COMMANDS_HELP

    await update.message.reply_text(
        intro + plan_text,
        reply_markup=ReplyKeyboardRemove(),
        parse_mode="Markdown",
    )
    # Show persistent main menu with inline keyboard
    await update.message.reply_text(
        format_main_menu(name, plan_type),
        reply_markup=main_menu_keyboard(),
        parse_mode="Markdown",
    )
    return ConversationHandler.END


# ── Utility ────────────────────────────────────────────────────────────────

async def cmd_cancel(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    await update.message.reply_text("Cancelled.", reply_markup=ReplyKeyboardRemove())
    return ConversationHandler.END


async def cmd_reset(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    telegram_id = str(update.effective_user.id)
    async with httpx.AsyncClient(timeout=10) as client:
        await client.delete(f"{API_BASE_URL}/athlete/{telegram_id}")
    context.user_data.clear()
    await update.message.reply_text(
        "🗑️ Profile deleted. Use /start to set up a new plan.",
        reply_markup=ReplyKeyboardRemove(),
    )
